# Copia este archivo como .env y rellena tus API keys

# VirusTotal (gratuito en https://www.virustotal.com)
VIRUSTOTAL_KEY=tu_api_key_aqui

# AbuseIPDB (gratuito en https://www.abuseipdb.com)
ABUSEIPDB_KEY=tu_api_key_aqui

# AlienVault OTX (opcional, gratuito en https://otx.alienvault.com)
ALIENVAULT_KEY=tu_api_key_aqui

# URLhaus, MalwareBazaar y ThreatFox no requieren API key
